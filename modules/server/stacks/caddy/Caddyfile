{
	email mjr@undead.one

	acme_dns porkbun {
		api_key {$PORKBUN_API_KEY}
		api_secret_key {$PORKBUN_API_SECRET_KEY}
	}
}

*.undead.one {
	tls {
		dns porkbun {
			api_key {$PORKBUN_API_KEY}
			api_secret_key {$PORKBUN_API_SECRET_KEY}
		}
		resolvers 1.1.1.1
	}

	@pihole host pihole.undead.one
	handle @pihole {
		reverse_proxy http://host.docker.internal:8081
	}

	@truenas host truenas.undead.one
	handle @truenas {
		reverse_proxy http://10.12.1.99:8080 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	@karakeep host karakeep.undead.one
